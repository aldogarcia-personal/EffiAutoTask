{
  "name": "effiautotask-monorepo",
  "version": "1.0.0",
  "description": "EffiAutoTask - Automated Task Management with pnpm workspaces",
  "packageManager": "pnpm@10.15.0+sha512.486ebc259d3e999a4e8691ce03b5cac4a71cbeca39372a9b762cb500cfdf0873e2cb16abe3d951b1ee2cf012503f027b98b6584e4df22524e0c7450d9ec7aa7b",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "pnpm --recursive run dev",
    "build": "pnpm --recursive run build",
    "lint": "pnpm --recursive run lint",
    "test": "pnpm --recursive run test",
    "start": "pnpm --dir server/backend start",
    "frontend": "pnpm -C client/fronted/EffiAutoTask",
    "backend": "pnpm --dir server/backend",
    "frontend:dev": "pnpm -C client/fronted/EffiAutoTask run dev",
    "backend:dev": "pnpm --dir server/backend run dev"
  },
  "private": true
}
